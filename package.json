{
  "name": "slider",
  "private": true,
  "workspaces": [
    "shared",
    "mock-server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently --names mock,ui --prefix-colors cyan,magenta \"npm run mock\" \"npm run ui\"",
    "mock": "npm run dev --workspace=mock-server",
    "ui": "npm run dev --workspace=web"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
